---
import Layout from '../layouts/Layout.astro';

// Automatically find all markdown articles
const posts = await Astro.glob('./articles/*.md');
const sortedPosts = posts.sort((a, b) => 
	new Date(b.frontmatter.pubDate).getTime() - new Date(a.frontmatter.pubDate).getTime()
);
---

<Layout title="Articles | Stackin Paper">
	<main class="max-w-4xl mx-auto px-6 py-12">
		<header class="mb-16">
            <h1 class="text-2xl md:text-5xl text-[#bdaa8b] tracking-tight whitespace-nowrap overflow-hidden font-serif">
                Articles
            </h1>
			<p class="text-slate-600 font-mono text-sm">Notes on implementation struggles, architectural decisions, and research findings.</p>
		</header>

		<div class="space-y-12">
			{sortedPosts.map((post) => (
				<article class="group relative">
					<div class="flex items-baseline gap-4 mb-2">
						<time class="font-mono text-xs text-slate-400">{post.frontmatter.pubDate}</time>
						<div class="h-[1px] flex-grow bg-slate-200 group-hover:bg-blue-300 transition-colors"></div>
					</div>
					
					<a href={post.url} class="block">
						<h2 class="text-2xl font-bold text-slate-900 group-hover:text-blue-600 transition-colors mb-2">
							{post.frontmatter.title}
						</h2>
						<p class="text-slate-600 leading-relaxed mb-4">
							{post.frontmatter.description}
						</p>
						<div class="flex gap-2">
							{post.frontmatter.tags?.map((tag: string) => (
								<span class="bg-slate-200 text-slate-700 px-2 py-1 text-[10px] font-bold uppercase tracking-wider rounded">
									{tag}
								</span>
							))}
						</div>
					</a>
				</article>
			))}
		</div>

		{posts.length === 0 && (
			<div class="py-20 text-center border-2 border-dashed border-slate-200 rounded-lg">
				<p class="text-slate-400 font-mono">No articles published yet. Initializing research logs...</p>
			</div>
		)}
	</main>
</Layout>