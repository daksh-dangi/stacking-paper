---
import Layout from '../layouts/Layout.astro';
// This JSON will be generated by the build script we wrote earlier
import projects from '../data/projects.json';
---

<Layout title="Projects | Stackin Paper">
  <main class="max-w-6xl mx-auto px-6 py-12">
    <h1 class="text-4xl font-black mb-12 tracking-tighter underline decoration-blue-500">PROJECTS</h1>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
      {projects.map((project) => (
        <a 
          href={project.url} 
          target="_blank"
          class="group relative flex items-center bg-[#7ec4f2] p-8 rounded-sm transition-all hover:scale-[1.02] hover:shadow-xl border-b-4 border-r-4 border-blue-400"
        >
          <div class="w-20 h-20 bg-[#fde68a] flex-shrink-0 shadow-lg border border-yellow-300"></div>
          
          <div class="ml-8">
            <h2 class="text-3xl font-mono font-black text-slate-900 uppercase leading-none">
              {project.name}
            </h2>
            <p class="text-slate-800 mt-2 font-medium opacity-80 group-hover:opacity-100">
              {project.description || "Research Implementation"}
            </p>
            <span class="inline-block mt-4 text-xs font-bold uppercase tracking-widest text-blue-900">
              Explore Repository →
            </span>
          </div>
        </a>
      ))}
    </div>
  </main>
</Layout>