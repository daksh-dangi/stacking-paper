---
interface Props {
	title: string;
}

const { title } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href=`${base}/favicon.svg` />
		<title>{title}</title>
		<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700;800&family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
	</head>
	<body class="bg-slate-50 font-sans selection:bg-blue-200">
		<nav class="border-b border-slate-200 bg-white sticky top-0 z-50">
			<div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
				<a href=`${base}/` class="font-black tracking-tighter text-xl">STACKIN PAPER</a>
				<div class="flex gap-8 font-mono text-sm font-bold uppercase">
					<a href=`${base}/projects` class="hover:text-blue-600 transition-colors">/projects</a>
					<a href=`${base}/articles` class="hover:text-blue-600 transition-colors">/articles</a>
				</div>
			</div>
		</nav>
		<slot />
		<footer class="py-12 border-t border-slate-200 mt-20">
			<div class="max-w-6xl mx-auto px-6 text-slate-400 font-mono text-xs">
				&copy; 2026 STACKIN PAPER // RESEARCH & IMPLEMENTATION LOG
			</div>
		</footer>
	</body>
</html>

<style is:global>
	@tailwind base;
	@tailwind components;
	@tailwind utilities;
	
	:root {
		--accent: 59, 130, 246;
	}
	html {
		font-family: 'Inter', system-ui, sans-serif;
	}
	code {
		font-family: 'JetBrains Mono', monospace;
	}
</style>